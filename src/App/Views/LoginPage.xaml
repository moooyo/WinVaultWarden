<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="App.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:App.Converters">

    <Page.Resources>
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <Grid>
        <Border MaxWidth="380" Margin="24" Padding="32"
                HorizontalAlignment="Center" VerticalAlignment="Center"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1" CornerRadius="12">
            <StackPanel Spacing="16">
                <!-- 品牌 -->
                <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center">
                    <Border Width="40" Height="40" CornerRadius="10"
                            Background="{ThemeResource AccentFillColorDefaultBrush}">
                        <TextBlock Text="V" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" FontWeight="Bold" FontSize="22"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="WinVaultWarden" FontSize="22" FontWeight="SemiBold"
                               VerticalAlignment="Center" />
                </StackPanel>

                <TextBlock Text="登录到你的保险库" HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                <TextBox Header="服务器地址" PlaceholderText="https://vault.example.com"
                         Text="{x:Bind ViewModel.ServerUrl, Mode=TwoWay}"
                         IsEnabled="{x:Bind ViewModel.CanEditServer, Mode=OneWay}" />
                <TextBox Header="邮箱" PlaceholderText="you@example.com"
                         Text="{x:Bind ViewModel.Email, Mode=TwoWay}"
                         IsEnabled="{x:Bind ViewModel.CanEditServer, Mode=OneWay}" />
                <PasswordBox Header="主密码"
                             Password="{x:Bind ViewModel.MasterPassword, Mode=TwoWay}" />
                <TextBox Header="两步验证码"
                         Text="{x:Bind ViewModel.TwoFactorCode, Mode=TwoWay}"
                         Visibility="{x:Bind ViewModel.IsTwoFactorStage, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}" />

                <Button Content="{x:Bind ViewModel.PrimaryButtonText, Mode=OneWay}"
                        Click="OnLogin"
                        Style="{ThemeResource AccentButtonStyle}"
                        HorizontalAlignment="Stretch" />

                <TextBlock Text="{x:Bind ViewModel.Status, Mode=OneWay}"
                           Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                           TextWrapping="Wrap" HorizontalAlignment="Center" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
