<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="App.Views.GeneratorHistoryDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:App.ViewModels.Models"
    Title="生成器历史记录"
    CloseButtonText="关闭"
    PrimaryButtonText="清除历史记录"
    PrimaryButtonClick="OnPrimaryButtonClick"
    MinWidth="520">

    <ListView ItemsSource="{x:Bind ViewModel.History}"
              SelectionMode="None">
        <ListView.ItemTemplate>
            <DataTemplate x:DataType="models:GeneratorHistoryItem">
                <Grid MinHeight="56" ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{x:Bind Value}"
                                   FontFamily="{StaticResource MonospaceFontFamily}"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{x:Bind CreatedAtText}"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   FontSize="12" />
                    </StackPanel>
                    <Button Grid.Column="1"
                            Width="36"
                            Height="32"
                            Padding="0"
                            AutomationProperties.Name="复制历史记录"
                            ToolTipService.ToolTip="复制"
                            Click="OnCopyClick">
                        <FontIcon Glyph="&#xE8C8;" FontSize="14" />
                    </Button>
                </Grid>
            </DataTemplate>
        </ListView.ItemTemplate>
    </ListView>
</ContentDialog>
