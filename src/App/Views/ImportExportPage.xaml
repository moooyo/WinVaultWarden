<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="App.Views.ImportExportPage"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:App.Converters">
    <Page.Resources>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
        <conv:EmptyStringToCollapsedConverter x:Key="EmptyStringToCollapsed" />
    </Page.Resources>

    <ScrollViewer Padding="{StaticResource PageContentPadding}">
        <StackPanel Spacing="24" MaxWidth="800" HorizontalAlignment="Left">

            <!-- 页面标题 -->
            <TextBlock Text="导入导出" Style="{ThemeResource TitleTextBlockStyle}" />

            <!-- ── 导出 ─────────────────────────────────────────────────────── -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CardCornerRadius}"
                    Padding="{StaticResource CardContentPadding}">
                <StackPanel Spacing="12">
                    <TextBlock Text="导出密码库" Style="{ThemeResource SubtitleTextBlockStyle}" />

                    <InfoBar IsClosable="False"
                             IsOpen="True"
                             Severity="Warning"
                             Title="导出文件包含明文密码"
                             Message="导出文件中的用户名、密码等字段均为未加密明文，请妥善保管并及时删除，不要通过不安全渠道传输。" />

                    <ComboBox Header="导出格式"
                              MinWidth="200"
                              AutomationProperties.AutomationId="ExportFormatCombo"
                              SelectedIndex="{x:Bind ViewModel.ExportFormatIndex, Mode=TwoWay}">
                        <ComboBoxItem Content="Bitwarden JSON" />
                        <ComboBoxItem Content="CSV" />
                    </ComboBox>

                    <Button Content="导出"
                            Style="{ThemeResource AccentButtonStyle}"
                            AutomationProperties.AutomationId="ExportButton"
                            Click="OnExportClick" />
                </StackPanel>
            </Border>

            <!-- ── 导入 ─────────────────────────────────────────────────────── -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="{StaticResource CardCornerRadius}"
                    Padding="{StaticResource CardContentPadding}">
                <StackPanel Spacing="12">
                    <TextBlock Text="导入密码库" Style="{ThemeResource SubtitleTextBlockStyle}" />

                    <ComboBox Header="导入格式"
                              MinWidth="200"
                              AutomationProperties.AutomationId="ImportFormatCombo"
                              SelectedIndex="{x:Bind ViewModel.ImportFormatIndex, Mode=TwoWay}">
                        <ComboBoxItem Content="Bitwarden JSON" />
                        <ComboBoxItem Content="CSV" />
                    </ComboBox>

                    <Button Content="选择文件"
                            AutomationProperties.AutomationId="ImportChooseFileButton"
                            Click="OnChooseImportFileClick" />

                    <InfoBar IsClosable="False"
                             Severity="Error"
                             Title="解析失败"
                             AutomationProperties.AutomationId="ImportErrorInfoBar"
                             IsOpen="{x:Bind ViewModel.HasImportError, Mode=OneWay}"
                             Message="{x:Bind ViewModel.ImportError, Mode=OneWay}" />

                    <StackPanel Spacing="4"
                                Visibility="{x:Bind ViewModel.HasImportError, Mode=OneWay,
                                    Converter={StaticResource InverseBoolToVis}}">
                        <TextBlock>
                            <Run Text="预览：" />
                            <Run Text="{x:Bind ViewModel.PreviewCipherCount, Mode=OneWay}" />
                            <Run Text=" 个条目，" />
                            <Run Text="{x:Bind ViewModel.PreviewFolderCount, Mode=OneWay}" />
                            <Run Text=" 个文件夹" />
                        </TextBlock>
                    </StackPanel>

                    <Button Content="导入"
                            Style="{ThemeResource AccentButtonStyle}"
                            AutomationProperties.AutomationId="ImportButton"
                            Command="{x:Bind ViewModel.DoImportCommand}" />

                    <TextBlock Text="{x:Bind ViewModel.ResultMessage, Mode=OneWay}"
                               AutomationProperties.AutomationId="ImportResultText"
                               Style="{ThemeResource BodyTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"
                               Visibility="{x:Bind ViewModel.ResultMessage, Mode=OneWay,
                                   Converter={StaticResource EmptyStringToCollapsed}}" />
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
