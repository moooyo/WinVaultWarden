<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="App.Views.VaultPage"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:App.Views"
    xmlns:controls="using:App.Controls"
    xmlns:conv="using:App.Converters"
    xmlns:models="using:App.ViewModels.Models">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
        <conv:EmptyStringToCollapsedConverter x:Key="EmptyToCollapsed" />
        <CollectionViewSource x:Name="GroupedItemsSource"
                              IsSourceGrouped="True"
                              ItemsPath="Items" />
        <DataTemplate x:Key="LoginTemplate" x:DataType="models:LoginDetail">
            <StackPanel Spacing="12">
                <controls:DetailCard Title="登录信息">
                    <controls:DetailCard.CardContent>
                        <StackPanel Spacing="2">
                            <controls:FieldRow Label="用户名" Value="{x:Bind Username}" />
                            <controls:FieldRow Label="密码" Value="{x:Bind Password}" IsSecret="True" />
                            <controls:TotpField Code="{x:Bind TotpSecret}" />
                        </StackPanel>
                    </controls:DetailCard.CardContent>
                </controls:DetailCard>
                <controls:DetailCard Title="自动填充">
                    <controls:DetailCard.CardContent>
                        <controls:FieldRow Label="网址" Value="{x:Bind Uri}" ShowOpen="True" />
                    </controls:DetailCard.CardContent>
                </controls:DetailCard>
                <controls:DetailCard Title="Passkey"
                                     Visibility="{x:Bind HasPasskeys, Converter={StaticResource BoolToVis}}">
                    <controls:DetailCard.CardContent>
                        <ItemsControl ItemsSource="{x:Bind Passkeys}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="models:PasskeyDetail">
                                    <StackPanel Spacing="2">
                                        <controls:FieldRow Label="RP ID" Value="{x:Bind RpId}" />
                                        <controls:FieldRow Label="账号" Value="{x:Bind DisplayName}" />
                                        <controls:FieldRow Label="可发现" Value="{x:Bind DiscoverableText}" />
                                        <controls:FieldRow Label="创建" Value="{x:Bind CreatedText}" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </controls:DetailCard.CardContent>
                </controls:DetailCard>
            </StackPanel>
        </DataTemplate>
        <DataTemplate x:Key="CardTemplate" x:DataType="models:CardDetail">
            <controls:DetailCard Title="卡信息">
                <controls:DetailCard.CardContent>
                    <StackPanel Spacing="2">
                        <controls:FieldRow Label="持卡人" Value="{x:Bind Cardholder}" />
                        <controls:FieldRow Label="卡号" Value="{x:Bind Number}" IsSecret="True" />
                        <controls:FieldRow Label="有效期" Value="{x:Bind Expiry}" />
                        <controls:FieldRow Label="品牌" Value="{x:Bind Brand}" />
                        <controls:FieldRow Label="CVV" Value="{x:Bind Cvv}" IsSecret="True" />
                    </StackPanel>
                </controls:DetailCard.CardContent>
            </controls:DetailCard>
        </DataTemplate>
        <DataTemplate x:Key="IdentityTemplate" x:DataType="models:IdentityDetail">
            <controls:DetailCard Title="个人信息">
                <controls:DetailCard.CardContent>
                    <StackPanel Spacing="2">
                        <controls:FieldRow Label="姓名" Value="{x:Bind FullName}" />
                        <controls:FieldRow Label="用户名" Value="{x:Bind Username}" />
                        <controls:FieldRow Label="公司" Value="{x:Bind Company}" />
                        <controls:FieldRow Label="邮箱" Value="{x:Bind Email}" />
                        <controls:FieldRow Label="电话" Value="{x:Bind Phone}" />
                        <controls:FieldRow Label="证件号" Value="{x:Bind IdNumber}" IsSecret="True" />
                        <controls:FieldRow Label="地址" Value="{x:Bind Address}" />
                    </StackPanel>
                </controls:DetailCard.CardContent>
            </controls:DetailCard>
        </DataTemplate>
        <DataTemplate x:Key="NoteTemplate" x:DataType="models:NoteDetail">
            <controls:DetailCard Title="内容">
                <controls:DetailCard.CardContent>
                    <TextBlock Text="{x:Bind Content}" TextWrapping="Wrap" />
                </controls:DetailCard.CardContent>
            </controls:DetailCard>
        </DataTemplate>
        <DataTemplate x:Key="SshTemplate" x:DataType="models:SshDetail">
            <controls:DetailCard Title="密钥">
                <controls:DetailCard.CardContent>
                    <StackPanel Spacing="2">
                        <controls:FieldRow Label="公钥" Value="{x:Bind PublicKey}" />
                        <controls:FieldRow Label="私钥" Value="{x:Bind PrivateKey}" IsSecret="True" />
                        <controls:FieldRow Label="指纹" Value="{x:Bind Fingerprint}" />
                    </StackPanel>
                </controls:DetailCard.CardContent>
            </controls:DetailCard>
        </DataTemplate>

    </Page.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="360" MinWidth="320" MaxWidth="420" />
            <ColumnDefinition Width="*" MinWidth="380" />
        </Grid.ColumnDefinitions>

        <!-- 列表 -->
        <Grid Grid.Column="0" Padding="12" RowSpacing="10"
              BorderThickness="0,0,1,0" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <AutoSuggestBox PlaceholderText="搜索你的保险库…"
                                Text="{x:Bind ViewModel.SearchText, Mode=TwoWay}"
                                QueryIcon="Find"
                                AutomationProperties.Name="搜索保险库"
                                AutomationProperties.AutomationId="VaultSearchBox" />
                <Button Grid.Column="1" Command="{x:Bind ViewModel.SyncCommand}"
                        AutomationProperties.Name="同步保险库"
                        AutomationProperties.AutomationId="VaultSyncButton">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE895;" FontSize="14" />
                        <TextBlock Text="同步" />
                    </StackPanel>
                </Button>
            </Grid>
            <CommandBar Grid.Row="1" DefaultLabelPosition="Right" HorizontalAlignment="Left"
                        Background="Transparent">
                <AppBarButton x:Name="AddCipherButton" Icon="Add" Label="新增">
                    <AppBarButton.Flyout>
                        <MenuFlyout>
                            <MenuFlyoutItem Text="登录" Click="OnAddLoginClick">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE7B7;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem Text="支付卡" Click="OnAddCardClick">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE8C7;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem Text="身份" Click="OnAddIdentityClick">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE77B;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem Text="笔记" Click="OnAddNoteClick">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE70B;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutItem Text="SSH 密钥" Click="OnAddSshClick">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE72E;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                            <MenuFlyoutSeparator />
                            <MenuFlyoutItem x:Name="AddFolderMenuItem"
                                            Text="文件夹"
                                            Click="OnAddFolderClick">
                                <MenuFlyoutItem.Icon>
                                    <FontIcon Glyph="&#xE8B7;" />
                                </MenuFlyoutItem.Icon>
                            </MenuFlyoutItem>
                        </MenuFlyout>
                    </AppBarButton.Flyout>
                </AppBarButton>
                <AppBarButton Icon="SelectAll" Label="全选"
                              Command="{x:Bind ViewModel.SelectAllCommand}"
                              IsEnabled="{x:Bind ViewModel.IsSelectionMode, Mode=OneWay}" />
                <AppBarButton Icon="MoveToFolder" Label="移动"
                              Command="{x:Bind ViewModel.MoveSelectedToFolderCommand}"
                              CommandParameter="{x:Null}"
                              IsEnabled="{x:Bind ViewModel.HasSelectionForMove, Mode=OneWay}" />
            </CommandBar>
            <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12" Margin="0,4,0,0"
                        Visibility="{x:Bind ViewModel.IsSelectionMode, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <TextBlock VerticalAlignment="Center"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="{x:Bind ViewModel.SelectedCount, Mode=OneWay}" />
                <TextBlock VerticalAlignment="Center" Text="项已选" />
                <Button Content="完成" Command="{x:Bind ViewModel.ToggleSelectionModeCommand}" />
            </StackPanel>
            <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8"
                        Visibility="{x:Bind ViewModel.IsFolderFilterSelected, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <Button x:Name="RenameFolderButton" Content="重命名文件夹" Click="OnRenameFolderClick" />
                <Button x:Name="DeleteFolderButton" Content="删除文件夹" Click="OnDeleteFolderClick" />
                <ProgressRing IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" Width="20" Height="20" />
            </StackPanel>
            <ListView Grid.Row="4"
                      x:Name="CipherList"
                      ItemsSource="{x:Bind GroupedItemsSource.View, Mode=OneWay}"
                      SelectedItem="{x:Bind ViewModel.SelectedItem, Mode=TwoWay}"
                      SelectionMode="{x:Bind local:VaultPage.SelectionModeFromBool(ViewModel.IsSelectionMode), Mode=OneWay}">
                <ListView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsStackPanel AreStickyGroupHeadersEnabled="True" />
                    </ItemsPanelTemplate>
                </ListView.ItemsPanel>
                <ListView.GroupStyle>
                    <GroupStyle HidesIfEmpty="True">
                        <GroupStyle.HeaderTemplate>
                            <DataTemplate x:DataType="models:VaultListGroup">
                                <StackPanel Orientation="Horizontal"
                                            Spacing="8"
                                            Margin="4,8,0,2"
                                            Visibility="{x:Bind local:VaultPage.VisibleIfTrue(ShowHeader)}">
                                    <TextBlock Text="{x:Bind Key}" Style="{StaticResource SectionHeaderTextBlockStyle}" />
                                    <TextBlock Text="{x:Bind Count}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </DataTemplate>
                        </GroupStyle.HeaderTemplate>
                    </GroupStyle>
                </ListView.GroupStyle>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:CipherListItem">
                        <Grid x:Name="RowRoot"
                              ColumnSpacing="10"
                              Padding="4,6"
                              PointerEntered="OnRowPointerEntered"
                              PointerExited="OnRowPointerExited"
                              GotFocus="OnRowGotFocus"
                              LostFocus="OnRowLostFocus">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Width="32" Height="32"
                                    Style="{StaticResource IconBadgeBorderStyle}">
                                <FontIcon Glyph="{x:Bind Glyph}" FontSize="16" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" />
                                <TextBlock Text="{x:Bind Subtitle}" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <FontIcon Grid.Column="2"
                                      Glyph="&#xE735;"
                                      FontSize="14"
                                      Margin="0,0,4,0"
                                      VerticalAlignment="Center"
                                      Foreground="{ThemeResource SystemFillColorAttentionBrush}"
                                      Visibility="{x:Bind local:VaultPage.VisibleIfTrue(Favorite)}" />
                            <StackPanel x:Name="RowActions"
                                        Grid.Column="3"
                                        Orientation="Horizontal"
                                        Spacing="2"
                                        Opacity="0"
                                        VerticalAlignment="Center">
                                <Button Style="{StaticResource IconButtonStyle}"
                                        AutomationProperties.Name="复制"
                                        AutomationProperties.AutomationId="VaultRowCopyButton"
                                        ToolTipService.ToolTip="复制主值"
                                        Command="{Binding ElementName=Root, Path=ViewModel.CopyPrimaryCommand}"
                                        CommandParameter="{x:Bind Id}">
                                    <FontIcon Glyph="&#xE8C8;" FontSize="14" />
                                </Button>
                                <Button Style="{StaticResource IconButtonStyle}"
                                        AutomationProperties.Name="更多"
                                        AutomationProperties.AutomationId="VaultRowMoreButton"
                                        ToolTipService.ToolTip="更多操作">
                                    <FontIcon Glyph="&#xE712;" FontSize="14" />
                                    <Button.Flyout>
                                        <MenuFlyout>
                                            <MenuFlyoutItem Text="编辑"
                                                            Click="OnRowEditClick"
                                                            Visibility="{x:Bind local:VaultPage.VisibleIfFalse(IsDeleted)}">
                                                <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE70F;" /></MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                            <MenuFlyoutItem Text="收藏 / 取消收藏"
                                                            Click="OnRowFavoriteClick"
                                                            Visibility="{x:Bind local:VaultPage.VisibleIfFalse(IsDeleted)}">
                                                <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE734;" /></MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                            <MenuFlyoutItem Text="移到回收站"
                                                            Click="OnRowSoftDeleteClick"
                                                            Visibility="{x:Bind local:VaultPage.VisibleIfFalse(IsDeleted)}">
                                                <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE74D;" /></MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                            <MenuFlyoutItem Text="恢复"
                                                            Click="OnRowRestoreClick"
                                                            Visibility="{x:Bind local:VaultPage.VisibleIfTrue(IsDeleted)}">
                                                <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE7A7;" /></MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                            <MenuFlyoutItem Text="永久删除"
                                                            Click="OnRowPermanentDeleteClick"
                                                            Visibility="{x:Bind local:VaultPage.VisibleIfTrue(IsDeleted)}">
                                                <MenuFlyoutItem.Icon><FontIcon Glyph="&#xE74D;" /></MenuFlyoutItem.Icon>
                                            </MenuFlyoutItem>
                                        </MenuFlyout>
                                    </Button.Flyout>
                                </Button>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <InfoBar x:Name="VaultErrorInfoBar"
                     Grid.Row="3"
                     VerticalAlignment="Top"
                     IsClosable="True"
                     Severity="Error"
                     IsOpen="{x:Bind ViewModel.HasOperationError, Mode=OneWay}"
                     Message="{x:Bind ViewModel.OperationError, Mode=OneWay}" />

            <StackPanel x:Name="VaultEmptyPanel"
                        Grid.Row="3"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Spacing="{StaticResource SpacingMedium}"
                        Visibility="{x:Bind ViewModel.HasNoItems, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <FontIcon Glyph="&#xE8A1;" FontSize="44"
                          Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                          HorizontalAlignment="Center" />
                <TextBlock Text="保险库为空"
                           Style="{ThemeResource SubtitleTextBlockStyle}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="点击上方&#x201C;新增&#x201D;创建你的第一个条目。"
                           Style="{StaticResource CaptionSecondaryTextBlockStyle}"
                           TextAlignment="Center"
                           HorizontalAlignment="Center" />
            </StackPanel>

            <StackPanel x:Name="VaultNoResultsPanel"
                        Grid.Row="3"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Spacing="{StaticResource SpacingMedium}"
                        Visibility="{x:Bind ViewModel.NoResults, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <FontIcon Glyph="&#xE721;" FontSize="44"
                          Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                          HorizontalAlignment="Center" />
                <TextBlock Text="没有匹配项"
                           Style="{ThemeResource SubtitleTextBlockStyle}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="没有符合当前搜索或筛选的条目。"
                           Style="{StaticResource CaptionSecondaryTextBlockStyle}"
                           TextAlignment="Center"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>

        <!-- 详情 -->
        <ScrollViewer Grid.Column="1" Padding="16">
            <StackPanel Spacing="12" MaxWidth="720" HorizontalAlignment="Left">
                <StackPanel x:Name="CipherEditorPanel"
                            Spacing="12"
                            DataContext="{x:Bind ViewModel}"
                            Visibility="{x:Bind ViewModel.IsEditing, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Spacing="6">
                            <TextBlock Text="{Binding EditorTitle, Mode=OneWay}"
                                       Style="{ThemeResource SubtitleTextBlockStyle}" />
                            <ComboBox x:Name="CipherEditorTypeBox"
                                      Header="类型"
                                      HorizontalAlignment="Stretch"
                                      SelectionChanged="OnCipherEditorTypeChanged">
                                <ComboBoxItem Content="登录" Tag="Login" />
                                <ComboBoxItem Content="支付卡" Tag="Card" />
                                <ComboBoxItem Content="身份" Tag="Identity" />
                                <ComboBoxItem Content="笔记" Tag="Note" />
                                <ComboBoxItem Content="SSH 密钥" Tag="Ssh" />
                            </ComboBox>
                        </StackPanel>

                        <Button x:Name="CancelCipherEditorButton"
                                Grid.Column="1"
                                Content="取消"
                                VerticalAlignment="Bottom"
                                Click="OnCancelCipherEditorClick" />
                        <Button x:Name="SaveCipherEditorButton"
                                Grid.Column="2"
                                Content="保存"
                                VerticalAlignment="Bottom"
                                Style="{StaticResource AccentButtonStyle}"
                                Click="OnSaveCipherEditorClick" />
                    </Grid>

                    <TextBlock Text="{Binding EditorError, Mode=OneWay}"
                               Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                               TextWrapping="Wrap"
                               Visibility="{Binding EditorError, Mode=OneWay, Converter={StaticResource EmptyToCollapsed}}" />
                    <TextBlock Text="{Binding OperationError, Mode=OneWay}"
                               Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                               TextWrapping="Wrap"
                               Visibility="{Binding OperationError, Mode=OneWay, Converter={StaticResource EmptyToCollapsed}}" />

                    <controls:DetailCard Title="项目详细信息">
                        <controls:DetailCard.CardContent>
                            <StackPanel Spacing="10">
                                <TextBox Header="项目名称（必填）"
                                         HorizontalAlignment="Stretch"
                                         Text="{Binding EditorDraft.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <ComboBox x:Name="CipherEditorFolderBox"
                                          Header="文件夹"
                                          HorizontalAlignment="Stretch"
                                          ItemsSource="{Binding FolderFilters}"
                                          DisplayMemberPath="Label"
                                          SelectedValuePath="FolderId"
                                          SelectedValue="{Binding EditorDraft.FolderId, Mode=TwoWay}"
                                          PlaceholderText="-- 选择 --" />
                                <CheckBox IsChecked="{Binding EditorDraft.Favorite, Mode=TwoWay}">
                                    <TextBlock Text="收藏" />
                                </CheckBox>
                            </StackPanel>
                        </controls:DetailCard.CardContent>
                    </controls:DetailCard>

                    <controls:DetailCard Title="登录凭据"
                                         Visibility="{Binding EditorDraft.IsLogin, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <controls:DetailCard.CardContent>
                            <StackPanel Spacing="10">
                                <TextBox Header="用户名"
                                         HorizontalAlignment="Stretch"
                                         Text="{Binding EditorDraft.Login.Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <PasswordBox Header="密码"
                                             HorizontalAlignment="Stretch"
                                             Password="{Binding EditorDraft.Login.Password, Mode=TwoWay}" />
                                <TextBox Header="验证器密钥"
                                         HorizontalAlignment="Stretch"
                                         Text="{Binding EditorDraft.Login.Totp, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Header="网站（URI）"
                                         HorizontalAlignment="Stretch"
                                         Text="{Binding EditorDraft.Login.Uris[0].Uri, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </controls:DetailCard.CardContent>
                    </controls:DetailCard>

                    <controls:DetailCard Title="支付卡信息"
                                         Visibility="{Binding EditorDraft.IsCard, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <controls:DetailCard.CardContent>
                            <StackPanel Spacing="10">
                                <TextBox Header="持卡人"
                                         HorizontalAlignment="Stretch"
                                         Text="{Binding EditorDraft.Card.CardholderName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <PasswordBox Header="卡号"
                                             HorizontalAlignment="Stretch"
                                             Password="{Binding EditorDraft.Card.Number, Mode=TwoWay}" />
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Header="到期月份"
                                             HorizontalAlignment="Stretch"
                                             Text="{Binding EditorDraft.Card.ExpMonth, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Grid.Column="1"
                                             Header="到期年份"
                                             HorizontalAlignment="Stretch"
                                             Text="{Binding EditorDraft.Card.ExpYear, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                                <PasswordBox Header="安全码"
                                             HorizontalAlignment="Stretch"
                                             Password="{Binding EditorDraft.Card.Code, Mode=TwoWay}" />
                                <Expander Header="更多支付卡字段">
                                    <TextBox Header="品牌"
                                             HorizontalAlignment="Stretch"
                                             Text="{Binding EditorDraft.Card.Brand, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </Expander>
                            </StackPanel>
                        </controls:DetailCard.CardContent>
                    </controls:DetailCard>

                    <controls:DetailCard Title="身份信息"
                                         Visibility="{Binding EditorDraft.IsIdentity, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <controls:DetailCard.CardContent>
                            <StackPanel Spacing="10">
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Header="名"
                                             HorizontalAlignment="Stretch"
                                             Text="{Binding EditorDraft.Identity.FirstName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <TextBox Grid.Column="1"
                                             Header="姓"
                                             HorizontalAlignment="Stretch"
                                             Text="{Binding EditorDraft.Identity.LastName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                </Grid>
                                <TextBox Header="电子邮箱"
                                         HorizontalAlignment="Stretch"
                                         Text="{Binding EditorDraft.Identity.Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Header="电话"
                                         HorizontalAlignment="Stretch"
                                         Text="{Binding EditorDraft.Identity.Phone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <TextBox Header="地址"
                                         HorizontalAlignment="Stretch"
                                         Text="{Binding EditorDraft.Identity.Address1, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                <Expander Header="更多身份字段">
                                    <StackPanel Spacing="10">
                                        <TextBox Header="用户名"
                                                 HorizontalAlignment="Stretch"
                                                 Text="{Binding EditorDraft.Identity.Username, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBox Header="公司"
                                                 HorizontalAlignment="Stretch"
                                                 Text="{Binding EditorDraft.Identity.Company, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <PasswordBox Header="社会安全号 / 身份号"
                                                     HorizontalAlignment="Stretch"
                                                     Password="{Binding EditorDraft.Identity.Ssn, Mode=TwoWay}" />
                                        <TextBox Header="护照号"
                                                 HorizontalAlignment="Stretch"
                                                 Text="{Binding EditorDraft.Identity.PassportNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </Expander>
                            </StackPanel>
                        </controls:DetailCard.CardContent>
                    </controls:DetailCard>

                    <controls:DetailCard Title="SSH 密钥"
                                         Visibility="{Binding EditorDraft.IsSshKey, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <controls:DetailCard.CardContent>
                            <StackPanel Spacing="10">
                                <TextBox Header="公钥"
                                         HorizontalAlignment="Stretch"
                                         Text="{Binding EditorDraft.SshKey.PublicKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         MinHeight="72"
                                         TextWrapping="Wrap" />
                                <PasswordBox Header="私钥"
                                             HorizontalAlignment="Stretch"
                                             Password="{Binding EditorDraft.SshKey.PrivateKey, Mode=TwoWay}" />
                                <TextBox Header="指纹"
                                         HorizontalAlignment="Stretch"
                                         Text="{Binding EditorDraft.SshKey.KeyFingerprint, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </controls:DetailCard.CardContent>
                    </controls:DetailCard>

                    <controls:DetailCard Title="安全笔记"
                                         Visibility="{Binding EditorDraft.IsSecureNote, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <controls:DetailCard.CardContent>
                            <TextBlock Text="安全笔记内容请填写在下方备注中。"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </controls:DetailCard.CardContent>
                    </controls:DetailCard>

                    <controls:DetailCard Title="附加选项">
                        <controls:DetailCard.CardContent>
                            <StackPanel Spacing="10">
                                <TextBox Header="备注"
                                         HorizontalAlignment="Stretch"
                                         Text="{Binding EditorDraft.Notes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         MinHeight="96"
                                         TextWrapping="Wrap" />
                                <CheckBox IsChecked="{Binding EditorDraft.Reprompt, Mode=TwoWay}">
                                    <TextBlock Text="主密码重新提示" />
                                </CheckBox>
                                <ItemsControl x:Name="CustomFieldsEditorItems"
                                              ItemsSource="{Binding EditorDraft.CustomFields}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid ColumnSpacing="8" Margin="0,4,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Spacing="8">
                                                    <TextBox Header="名称"
                                                             HorizontalAlignment="Stretch"
                                                             Text="{Binding Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                    <TextBox Header="值"
                                                             HorizontalAlignment="Stretch"
                                                             Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>
                                                <Button x:Name="RemoveCustomFieldButton"
                                                        Grid.Column="1"
                                                        Tag="{Binding}"
                                                        VerticalAlignment="Top"
                                                        Style="{StaticResource IconButtonStyle}"
                                                        AutomationProperties.Name="删除字段"
                                                        ToolTipService.ToolTip="删除字段"
                                                        Click="OnRemoveCustomFieldClick">
                                                    <FontIcon Glyph="&#xE74D;" FontSize="14" />
                                                </Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <Button x:Name="AddCustomFieldButton"
                                        Content="添加字段"
                                        HorizontalAlignment="Left"
                                        Click="OnAddCustomFieldClick" />
                            </StackPanel>
                        </controls:DetailCard.CardContent>
                    </controls:DetailCard>
                </StackPanel>

                <StackPanel Spacing="12"
                            Visibility="{x:Bind ViewModel.IsEditing, Mode=OneWay, Converter={StaticResource InverseBoolToVis}}">
                <StackPanel Spacing="2"
                            Visibility="{x:Bind ViewModel.HasSelection, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <FontIcon Glyph="{x:Bind ViewModel.SelectedItem.Glyph, Mode=OneWay}"
                                  FontSize="18" VerticalAlignment="Center" />
                        <TextBlock Text="{x:Bind ViewModel.Detail.Name, Mode=OneWay}"
                                   Style="{ThemeResource SubtitleTextBlockStyle}" />
                        <FontIcon Glyph="&#xE735;" FontSize="14"
                                  VerticalAlignment="Center"
                                  Foreground="{ThemeResource SystemFillColorAttentionBrush}"
                                  Visibility="{x:Bind local:VaultPage.VisibleIfTrue(ViewModel.Detail.Favorite), Mode=OneWay}" />
                    </StackPanel>
                    <TextBlock Text="{x:Bind ViewModel.Detail.FolderName, Mode=OneWay}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>
                <ContentControl x:Name="DetailHost"
                                HorizontalContentAlignment="Stretch" />

                <!-- 共用底部:备注/自定义字段/历史/操作 -->
                <StackPanel Spacing="12"
                            Visibility="{x:Bind ViewModel.HasSelection, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                    <!-- 备注 -->
                    <StackPanel Spacing="4"
                                Visibility="{x:Bind ViewModel.Detail.Notes, Mode=OneWay, Converter={StaticResource EmptyToCollapsed}}">
                        <TextBlock Text="备注" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.Detail.Notes, Mode=OneWay}" TextWrapping="Wrap" />
                    </StackPanel>
                    <!-- 自定义字段 -->
                    <ItemsControl ItemsSource="{x:Bind ViewModel.Detail.CustomFields, Mode=OneWay}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate x:DataType="models:CustomField">
                                <controls:FieldRow Label="{x:Bind Label}" Value="{x:Bind Value}" IsSecret="{x:Bind IsSecret}" />
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <!-- 历史 -->
                    <StackPanel Spacing="2">
                        <TextBlock Text="项目历史" Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                   Text="{x:Bind ViewModel.Detail.HistoryText, Mode=OneWay}" />
                    </StackPanel>
                    <!-- 操作错误条 -->
                    <TextBlock Text="{x:Bind ViewModel.OperationError, Mode=OneWay}"
                               Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                               TextWrapping="Wrap"
                               Visibility="{x:Bind ViewModel.OperationError, Mode=OneWay, Converter={StaticResource EmptyToCollapsed}}" />
                    <!-- 操作:常规(非回收站) -->
                    <Grid ColumnSpacing="8"
                          Visibility="{x:Bind ViewModel.IsSelectedItemDeleted, Mode=OneWay, Converter={StaticResource InverseBoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="EditCipherButton" HorizontalAlignment="Stretch" Click="OnEditCipherClick">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE70F;" FontSize="14" /><TextBlock Text="编辑" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="DeleteCipherButton" Grid.Column="1" HorizontalAlignment="Stretch" Click="OnDeleteCipherClick">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                                <TextBlock Text="删除" Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                            </StackPanel>
                        </Button>
                    </Grid>
                    <!-- 操作:回收站 -->
                    <Grid ColumnSpacing="8"
                          Visibility="{x:Bind ViewModel.IsSelectedItemDeleted, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button x:Name="RestoreCipherButton" HorizontalAlignment="Stretch" Click="OnRestoreCipherClick">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE7A7;" FontSize="14" /><TextBlock Text="恢复" />
                            </StackPanel>
                        </Button>
                        <Button x:Name="PermanentDeleteCipherButton" Grid.Column="1" HorizontalAlignment="Stretch" Click="OnPermanentDeleteCipherClick">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                                <TextBlock Text="永久删除" Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>

                <StackPanel Visibility="{x:Bind ViewModel.NoSelection, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                            HorizontalAlignment="Center"
                            Spacing="{StaticResource SpacingMedium}"
                            Margin="0,72,0,0">
                    <FontIcon Glyph="&#xE8F1;" FontSize="44"
                              Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                              HorizontalAlignment="Center" />
                    <TextBlock Text="未选择任何项目"
                               Style="{ThemeResource SubtitleTextBlockStyle}"
                               HorizontalAlignment="Center" />
                    <TextBlock Text="从左侧列表选择一个条目以查看详情。"
                               Style="{StaticResource CaptionSecondaryTextBlockStyle}"
                               TextAlignment="Center"
                               HorizontalAlignment="Center" />
                </StackPanel>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
