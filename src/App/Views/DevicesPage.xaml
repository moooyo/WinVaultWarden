<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="App.Views.DevicesPage"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:App.Converters"
    xmlns:models="using:App.ViewModels.Models"
    Loaded="OnPageLoaded">
    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>
    <ScrollViewer Padding="{StaticResource PageContentPadding}">
        <StackPanel Spacing="16" MaxWidth="640" HorizontalAlignment="Left">
            <TextBlock Text="设备管理" Style="{ThemeResource TitleTextBlockStyle}" />
            <InfoBar x:Name="DevicesErrorInfoBar"
                     IsClosable="True"
                     Severity="Error"
                     IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                     Message="{x:Bind ViewModel.Error, Mode=OneWay}" />
            <ProgressRing x:Name="DevicesBusyRing"
                          Width="24" Height="24"
                          HorizontalAlignment="Left"
                          IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" />
            <StackPanel x:Name="DevicesEmptyPanel"
                        HorizontalAlignment="Center"
                        Spacing="{StaticResource SpacingMedium}"
                        Margin="0,40,0,0"
                        Visibility="{x:Bind ViewModel.HasNoDevices, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <FontIcon Glyph="&#xE8EA;" FontSize="44"
                          Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                          HorizontalAlignment="Center" />
                <TextBlock Text="没有已登记的设备"
                           Style="{ThemeResource SubtitleTextBlockStyle}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="在此账户上登录后，设备会显示在这里。"
                           Style="{StaticResource CaptionSecondaryTextBlockStyle}"
                           TextAlignment="Center"
                           HorizontalAlignment="Center" />
            </StackPanel>
            <ItemsRepeater ItemsSource="{x:Bind ViewModel.Devices}">
                <ItemsRepeater.ItemTemplate>
                    <DataTemplate x:DataType="models:DeviceItem">
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="{StaticResource CardCornerRadius}" Padding="{StaticResource CardContentPadding}" Margin="0,0,0,8"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="{x:Bind Glyph}" FontSize="24" VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" />
                                        <Border Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                CornerRadius="4" Padding="6,1"
                                                Visibility="{x:Bind IsCurrent, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="当前设备" FontSize="12" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{x:Bind LastActive}"
                                               Style="{StaticResource CaptionSecondaryTextBlockStyle}" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsRepeater.ItemTemplate>
            </ItemsRepeater>

            <!-- ── 待批准的登录请求 ─────────────────────────────────── -->
            <StackPanel Spacing="8" Margin="0,16,0,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="待批准的登录请求"
                               Style="{ThemeResource SubtitleTextBlockStyle}"
                               VerticalAlignment="Center" />
                    <Button Grid.Column="1"
                            AutomationProperties.AutomationId="DevicesRefreshRequestsButton"
                            Content="刷新"
                            Click="OnRefreshRequestsClick"
                            Style="{ThemeResource DefaultButtonStyle}" />
                </Grid>

                <!-- 空状态 -->
                <TextBlock x:Name="RequestsEmptyText"
                           Text="当前没有待批准的登录请求。"
                           Style="{StaticResource CaptionSecondaryTextBlockStyle}"
                           Visibility="{x:Bind ViewModel.HasNoPendingRequests, Mode=OneWay, Converter={StaticResource BoolToVis}}" />

                <!-- 请求列表 -->
                <ItemsRepeater x:Name="PendingRequestsRepeater"
                               ItemsSource="{x:Bind ViewModel.PendingRequests, Mode=OneWay}">
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="models:AuthRequestItem">
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderThickness="1" CornerRadius="{StaticResource CardCornerRadius}" Padding="{StaticResource CardContentPadding}" Margin="0,0,0,8"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Text="{x:Bind DeviceTypeName}" FontWeight="SemiBold" />
                                        <TextBlock Text="{x:Bind IpAddress}"
                                                   Style="{StaticResource CaptionSecondaryTextBlockStyle}" />
                                        <TextBlock Text="{x:Bind CreatedLabel}"
                                                   Style="{StaticResource CaptionSecondaryTextBlockStyle}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <Button AutomationProperties.AutomationId="DevicesApproveRequestButton"
                                                Content="批准"
                                                Tag="{x:Bind}"
                                                Click="OnApproveRequestClick"
                                                Style="{ThemeResource AccentButtonStyle}" />
                                        <Button AutomationProperties.AutomationId="DevicesDenyRequestButton"
                                                Content="拒绝"
                                                Tag="{x:Bind}"
                                                Click="OnDenyRequestClick" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>
