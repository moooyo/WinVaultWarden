<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="App.Views.DevicesPage"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:App.Converters"
    xmlns:models="using:App.ViewModels.Models">
    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVis" />
    </Page.Resources>
    <ScrollViewer Padding="{StaticResource PageContentPadding}">
        <StackPanel Spacing="16" MaxWidth="640" HorizontalAlignment="Left">
            <TextBlock Text="设备管理" Style="{ThemeResource TitleTextBlockStyle}" />
            <ItemsControl ItemsSource="{x:Bind ViewModel.Devices}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="models:DeviceItem">
                        <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                BorderThickness="1" CornerRadius="{StaticResource CardCornerRadius}" Padding="16" Margin="0,0,0,8"
                                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                            <Grid ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <FontIcon Glyph="{x:Bind Glyph}" FontSize="24" VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" />
                                        <Border Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                CornerRadius="4" Padding="6,1"
                                                Visibility="{x:Bind IsCurrent, Converter={StaticResource BoolToVis}}">
                                            <TextBlock Text="当前设备" FontSize="11" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{x:Bind LastActive}" FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                                <Button Grid.Column="2" VerticalAlignment="Center"
                                        Visibility="{x:Bind IsCurrent, Converter={StaticResource InverseBoolToVis}}"
                                        Command="{Binding ElementName=Root, Path=ViewModel.RevokeCommand}"
                                        CommandParameter="{x:Bind}">
                                    <TextBlock Text="撤销" Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                                </Button>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </StackPanel>
    </ScrollViewer>
</Page>
