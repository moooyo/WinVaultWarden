<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="App.Views.EmergencyAccessPage"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:App.Converters"
    xmlns:models="using:Core.Models"
    Loaded="OnPageLoaded">
    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Page.Resources>

    <ScrollViewer Padding="{StaticResource PageContentPadding}">
        <StackPanel Spacing="16" MaxWidth="720" HorizontalAlignment="Left">

            <TextBlock Text="紧急访问" Style="{ThemeResource TitleTextBlockStyle}" />

            <!-- 错误提示 -->
            <InfoBar x:Name="EmergencyErrorBar"
                     IsClosable="True"
                     Severity="Error"
                     IsOpen="{x:Bind ViewModel.HasError, Mode=OneWay}"
                     Message="{x:Bind ViewModel.OperationError, Mode=OneWay}" />

            <!-- 忙碌指示 -->
            <ProgressRing x:Name="EmergencyBusyRing"
                          Width="24" Height="24"
                          HorizontalAlignment="Left"
                          IsActive="{x:Bind ViewModel.IsBusy, Mode=OneWay}" />

            <!-- ── 邀请按钮（InviteCommand via code-behind OnInviteClick）──── -->
            <!-- TakeoverCommand via code-behind OnTakeoverClick -->
            <!-- UpdateCommand via code-behind OnUpdateClick -->
            <Button AutomationProperties.AutomationId="EmergencyInviteButton"
                    Content="邀请紧急联系人"
                    Style="{ThemeResource AccentButtonStyle}"
                    Click="OnInviteClick" />

            <!-- ══════ 授予方视角：我的紧急联系人 ══════════════════════════ -->
            <StackPanel Spacing="8">
                <TextBlock Text="我的紧急联系人（授予方）"
                           Style="{StaticResource SectionHeaderTextBlockStyle}" />

                <!-- 空状态提示（条目数为零时显示） -->
                <TextBlock x:Name="ContactsEmptyText"
                           Text="尚未设置任何紧急联系人。"
                           Style="{StaticResource CaptionSecondaryTextBlockStyle}"
                           Visibility="Collapsed" />

                <ListView x:Name="MyContactsList"
                          ItemsSource="{x:Bind ViewModel.MyContacts, Mode=OneWay}"
                          SelectionMode="Single"
                          SelectionChanged="OnMyContactsSelectionChanged">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:EmergencyContact">
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource CardCornerRadius}"
                                    Padding="{StaticResource CardContentPadding}"
                                    Margin="0,0,0,8"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                <Grid RowSpacing="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <!-- 联系人信息 -->
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="{x:Bind Email}" FontWeight="SemiBold" />
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{x:Bind Status}"
                                                       Style="{StaticResource CaptionSecondaryTextBlockStyle}" />
                                            <TextBlock Text="|"
                                                       Style="{StaticResource CaptionSecondaryTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                            <TextBlock Text="{x:Bind Type}"
                                                       Style="{StaticResource CaptionSecondaryTextBlockStyle}" />
                                        </StackPanel>
                                    </StackPanel>
                                    <!-- 操作按钮 -->
                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
                                        <Button AutomationProperties.AutomationId="EmergencyConfirmButton"
                                                Content="确认"
                                                Tag="{x:Bind}"
                                                Click="OnConfirmClick" />
                                        <Button AutomationProperties.AutomationId="EmergencyReinviteButton"
                                                Content="重新邀请"
                                                Tag="{x:Bind}"
                                                Click="OnReinviteClick" />
                                        <Button AutomationProperties.AutomationId="EmergencyApproveButton"
                                                Content="批准"
                                                Tag="{x:Bind}"
                                                Click="OnApproveClick"
                                                Style="{ThemeResource AccentButtonStyle}" />
                                        <Button AutomationProperties.AutomationId="EmergencyRejectButton"
                                                Content="拒绝"
                                                Tag="{x:Bind}"
                                                Click="OnRejectClick" />
                                        <Button AutomationProperties.AutomationId="EmergencyRemoveContactButton"
                                                Content="移除"
                                                Tag="{x:Bind}"
                                                Click="OnRemoveContactClick" />
                                        <Button AutomationProperties.AutomationId="EmergencyUpdateButton"
                                                Content="修改"
                                                Tag="{x:Bind}"
                                                Click="OnUpdateClick" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>

            <!-- ══════ 受托方视角：信任我的账户 ═══════════════════════════════ -->
            <StackPanel Spacing="8" Margin="0,16,0,0">
                <TextBlock Text="信任我的账户（受托方）"
                           Style="{StaticResource SectionHeaderTextBlockStyle}" />

                <!-- 空状态提示（条目数为零时显示） -->
                <TextBlock x:Name="GrantedEmptyText"
                           Text="没有账户将您设为紧急联系人。"
                           Style="{StaticResource CaptionSecondaryTextBlockStyle}"
                           Visibility="Collapsed" />

                <ListView x:Name="TrustedByOthersList"
                          ItemsSource="{x:Bind ViewModel.TrustedByOthers, Mode=OneWay}"
                          SelectionMode="Single"
                          SelectionChanged="OnTrustedByOthersSelectionChanged">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem" BasedOn="{StaticResource DefaultListViewItemStyle}">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                            <Setter Property="Padding" Value="0" />
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:GrantedAccess">
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource CardCornerRadius}"
                                    Padding="{StaticResource CardContentPadding}"
                                    Margin="0,0,0,8"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                <Grid RowSpacing="8">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <!-- 授予方信息 -->
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="{x:Bind Email}" FontWeight="SemiBold" />
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{x:Bind Status}"
                                                       Style="{StaticResource CaptionSecondaryTextBlockStyle}" />
                                            <TextBlock Text="|"
                                                       Style="{StaticResource CaptionSecondaryTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                            <TextBlock Text="{x:Bind Type}"
                                                       Style="{StaticResource CaptionSecondaryTextBlockStyle}" />
                                        </StackPanel>
                                    </StackPanel>
                                    <!-- 操作按钮 -->
                                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
                                        <Button AutomationProperties.AutomationId="EmergencyInitiateButton"
                                                Content="发起紧急访问"
                                                Tag="{x:Bind}"
                                                Click="OnInitiateClick" />
                                        <Button AutomationProperties.AutomationId="EmergencyViewButton"
                                                Content="查看密码库"
                                                Tag="{x:Bind}"
                                                Click="OnViewClick" />
                                        <Button AutomationProperties.AutomationId="EmergencyTakeoverButton"
                                                Content="接管账户"
                                                Tag="{x:Bind}"
                                                Click="OnTakeoverClick" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>

            <!-- ══════ 已恢复的密码库（View 命令结果，只读）══════════════════ -->
            <StackPanel Spacing="8" Margin="0,16,0,0"
                        Visibility="{x:Bind ViewModel.HasRecoveredVault, Mode=OneWay, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="已恢复的密码库条目（只读）"
                           Style="{StaticResource SectionHeaderTextBlockStyle}" />
                <ListView x:Name="RecoveredItemsList"
                          ItemsSource="{x:Bind ViewModel.RecoveredItems, Mode=OneWay}"
                          SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:RecoveredVault">
                            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource CardCornerRadius}"
                                    Padding="{StaticResource CardContentPadding}"
                                    Margin="0,0,0,8"
                                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}">
                                <StackPanel Spacing="4">
                                    <TextBlock Text="{x:Bind GrantorEmail}" FontWeight="SemiBold" />
                                    <TextBlock Style="{StaticResource CaptionSecondaryTextBlockStyle}">
                                        <Run Text="条目数：" />
                                        <Run Text="{x:Bind Ciphers.Count}" />
                                    </TextBlock>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</Page>
