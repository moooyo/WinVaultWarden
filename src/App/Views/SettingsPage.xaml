<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <ScrollViewer Padding="24">
        <StackPanel Spacing="16" MaxWidth="640" HorizontalAlignment="Left">
            <TextBlock Text="账户设置" Style="{ThemeResource TitleTextBlockStyle}" />

            <!-- 个人资料 -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="个人资料" FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Width="40" Height="40" CornerRadius="20"
                                Background="{ThemeResource AccentFillColorDefaultBrush}">
                            <TextBlock Text="{x:Bind ViewModel.AccountInitial}" Foreground="White"
                                       FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.AccountEmail}"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="2" Content="编辑资料" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 外观 -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="外观" FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="主题" VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1" MinWidth="160"
                                  SelectedIndex="{x:Bind ViewModel.SelectedThemeIndex, Mode=TwoWay}">
                            <ComboBoxItem Content="跟随系统" />
                            <ComboBoxItem Content="浅色" />
                            <ComboBoxItem Content="深色" />
                        </ComboBox>
                    </Grid>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="语言" VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1" MinWidth="160" SelectedIndex="0">
                            <ComboBoxItem Content="简体中文" />
                            <ComboBoxItem Content="English" />
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 安全 -->
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="4">
                    <TextBlock Text="安全" FontSize="12" Margin="0,0,0,8"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Background="Transparent">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <TextBlock Text="修改主密码" VerticalAlignment="Center" />
                            <FontIcon Grid.Column="1" Glyph="&#xE76C;" FontSize="14" />
                        </Grid>
                    </Button>
                    <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch" Background="Transparent">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="加密设置" />
                                <TextBlock Text="{x:Bind ViewModel.KdfSummary}" FontSize="12"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                            </StackPanel>
                            <FontIcon Grid.Column="1" Glyph="&#xE76C;" FontSize="14" VerticalAlignment="Center" />
                        </Grid>
                    </Button>
                </StackPanel>
            </Border>

            <!-- 账户(危险区) -->
            <Border BorderBrush="{ThemeResource SystemFillColorCriticalBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="16">
                <StackPanel Spacing="8">
                    <TextBlock Text="账户" FontSize="12"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    <Button>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE74D;" FontSize="14"
                                      Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                            <TextBlock Text="删除账户"
                                       Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
