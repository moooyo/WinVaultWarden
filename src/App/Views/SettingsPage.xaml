<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="App.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Page.Resources>
        <Style x:Key="SettingsCaptionTextBlockStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        </Style>
        <Style x:Key="SettingsDescriptionTextBlockStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="WrapWholeWords" />
        </Style>
    </Page.Resources>

    <ScrollViewer Padding="24">
        <StackPanel Spacing="16" MaxWidth="680" HorizontalAlignment="Center">
            <TextBlock Text="设置" Style="{ThemeResource TitleTextBlockStyle}" />

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="账户" Style="{StaticResource SettingsCaptionTextBlockStyle}" />

                    <Grid ColumnSpacing="12" MinHeight="48">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Width="40"
                                Height="40"
                                CornerRadius="20"
                                Background="{ThemeResource AccentFillColorDefaultBrush}">
                            <TextBlock Text="{x:Bind ViewModel.AccountInitial}"
                                       Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{x:Bind ViewModel.AccountEmail}"
                                       FontWeight="SemiBold"
                                       TextTrimming="CharacterEllipsis" />
                            <TextBlock Text="{x:Bind ViewModel.AccountServer}"
                                       Style="{StaticResource SettingsDescriptionTextBlockStyle}"
                                       TextTrimming="CharacterEllipsis" />
                        </StackPanel>
                        <Button Grid.Column="2"
                                Content="编辑资料"
                                VerticalAlignment="Center" />
                    </Grid>

                    <Button HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            Background="Transparent">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="修改主密码" VerticalAlignment="Center" />
                            <FontIcon Grid.Column="1"
                                      Glyph="&#xE76C;"
                                      FontSize="14"
                                      VerticalAlignment="Center" />
                        </Grid>
                    </Button>

                    <Button HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            Background="Transparent">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="加密设置" />
                                <TextBlock Text="{x:Bind ViewModel.KdfSummary}"
                                           Style="{StaticResource SettingsDescriptionTextBlockStyle}" />
                            </StackPanel>
                            <FontIcon Grid.Column="1"
                                      Glyph="&#xE76C;"
                                      FontSize="14"
                                      VerticalAlignment="Center" />
                        </Grid>
                    </Button>
                </StackPanel>
            </Border>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="安全" Style="{StaticResource SettingsCaptionTextBlockStyle}" />

                    <Grid ColumnSpacing="12" MinHeight="44">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="会话超时" FontWeight="SemiBold" />
                            <TextBlock Text="超时后将密码库锁定或登出"
                                       Style="{StaticResource SettingsDescriptionTextBlockStyle}" />
                        </StackPanel>
                        <ComboBox Grid.Column="1"
                                  Width="220"
                                  HorizontalAlignment="Right"
                                  SelectedIndex="{x:Bind ViewModel.SelectedSessionTimeoutIndex, Mode=TwoWay}">
                            <ComboBoxItem Content="重启时" />
                            <ComboBoxItem Content="1 分钟" />
                            <ComboBoxItem Content="5 分钟" />
                            <ComboBoxItem Content="15 分钟" />
                            <ComboBoxItem Content="30 分钟" />
                            <ComboBoxItem Content="1 小时" />
                            <ComboBoxItem Content="4 小时" />
                            <ComboBoxItem Content="永不" />
                        </ComboBox>
                    </Grid>

                    <Grid ColumnSpacing="12" MinHeight="44">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="超时动作"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1"
                                  Width="220"
                                  HorizontalAlignment="Right"
                                  SelectedIndex="{x:Bind ViewModel.SelectedTimeoutActionIndex, Mode=TwoWay}">
                            <ComboBoxItem Content="锁定" />
                            <ComboBoxItem Content="登出" />
                        </ComboBox>
                    </Grid>

                    <Grid ColumnSpacing="12" MinHeight="44">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="使用 PIN 码解锁"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <ToggleSwitch Grid.Column="1"
                                      HorizontalAlignment="Right"
                                      IsOn="{x:Bind ViewModel.UsePinUnlock, Mode=TwoWay}" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="偏好设置" Style="{StaticResource SettingsCaptionTextBlockStyle}" />

                    <Grid ColumnSpacing="12" MinHeight="44">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="清空剪贴板" FontWeight="SemiBold" />
                            <TextBlock Text="自动清除复制到剪贴板的值"
                                       Style="{StaticResource SettingsDescriptionTextBlockStyle}" />
                        </StackPanel>
                        <ComboBox Grid.Column="1"
                                  Width="220"
                                  HorizontalAlignment="Right"
                                  SelectedIndex="{x:Bind ViewModel.SelectedClearClipboardIndex, Mode=TwoWay}">
                            <ComboBoxItem Content="永不" />
                            <ComboBoxItem Content="10 秒" />
                            <ComboBoxItem Content="20 秒" />
                            <ComboBoxItem Content="30 秒" />
                            <ComboBoxItem Content="1 分钟" />
                            <ComboBoxItem Content="2 分钟" />
                            <ComboBoxItem Content="5 分钟" />
                        </ComboBox>
                    </Grid>

                    <Grid ColumnSpacing="12" MinHeight="44">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="复制后最小化" FontWeight="SemiBold" />
                            <TextBlock Text="复制项目数据到剪贴板后最小化应用"
                                       Style="{StaticResource SettingsDescriptionTextBlockStyle}" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1"
                                      HorizontalAlignment="Right"
                                      IsOn="{x:Bind ViewModel.MinimizeOnCopy, Mode=TwoWay}" />
                    </Grid>

                    <Grid ColumnSpacing="12" MinHeight="44">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="显示网站图标/密码 URL"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center"
                                   TextWrapping="WrapWholeWords" />
                        <ToggleSwitch Grid.Column="1"
                                      HorizontalAlignment="Right"
                                      IsOn="{x:Bind ViewModel.ShowIconsAndPasswordUrl, Mode=TwoWay}" />
                    </Grid>
                </StackPanel>
            </Border>

            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="APP 设置（所有账户）" Style="{StaticResource SettingsCaptionTextBlockStyle}" />

                    <Grid ColumnSpacing="12" MinHeight="44">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="显示托盘图标" FontWeight="SemiBold" />
                            <TextBlock Text="始终在系统托盘中显示图标"
                                       Style="{StaticResource SettingsDescriptionTextBlockStyle}" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1"
                                      HorizontalAlignment="Right"
                                      IsOn="{x:Bind ViewModel.ShowTrayIcon, Mode=TwoWay}" />
                    </Grid>

                    <Grid ColumnSpacing="12" MinHeight="44">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="最小化到托盘" FontWeight="SemiBold" />
                            <TextBlock Text="最小化窗口后保留系统托盘入口"
                                       Style="{StaticResource SettingsDescriptionTextBlockStyle}" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1"
                                      HorizontalAlignment="Right"
                                      IsOn="{x:Bind ViewModel.MinimizeToTray, Mode=TwoWay}" />
                    </Grid>

                    <Grid ColumnSpacing="12" MinHeight="44">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="关闭到托盘" FontWeight="SemiBold" />
                            <TextBlock Text="关闭窗口后保留系统托盘入口"
                                       Style="{StaticResource SettingsDescriptionTextBlockStyle}" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1"
                                      HorizontalAlignment="Right"
                                      IsOn="{x:Bind ViewModel.CloseToTray, Mode=TwoWay}" />
                    </Grid>

                    <Grid ColumnSpacing="12" MinHeight="44">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="登录时自动启动" FontWeight="SemiBold" />
                            <TextBlock Text="登录 Windows 后自动启动应用"
                                       Style="{StaticResource SettingsDescriptionTextBlockStyle}" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1"
                                      HorizontalAlignment="Right"
                                      IsOn="{x:Bind ViewModel.StartOnLogin, Mode=TwoWay}" />
                    </Grid>

                    <Grid ColumnSpacing="12" MinHeight="44">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="允许浏览器集成" FontWeight="SemiBold" />
                            <TextBlock Text="允许浏览器扩展连接桌面应用"
                                       Style="{StaticResource SettingsDescriptionTextBlockStyle}" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1"
                                      HorizontalAlignment="Right"
                                      IsOn="{x:Bind ViewModel.AllowBrowserIntegration, Mode=TwoWay}" />
                    </Grid>

                    <Grid ColumnSpacing="12" MinHeight="44">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="使用硬件加速" FontWeight="SemiBold" />
                            <TextBlock Text="仅在遇到图形问题时关闭"
                                       Style="{StaticResource SettingsDescriptionTextBlockStyle}" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1"
                                      HorizontalAlignment="Right"
                                      IsOn="{x:Bind ViewModel.UseHardwareAcceleration, Mode=TwoWay}" />
                    </Grid>

                    <Grid ColumnSpacing="12" MinHeight="44">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="启用 SSH 代理" FontWeight="SemiBold" />
                            <TextBlock Text="允许应用处理 SSH 签名请求"
                                       Style="{StaticResource SettingsDescriptionTextBlockStyle}" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1"
                                      HorizontalAlignment="Right"
                                      IsOn="{x:Bind ViewModel.EnableSshAgent, Mode=TwoWay}" />
                    </Grid>

                    <Grid ColumnSpacing="12" MinHeight="44">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="SSH 授权提示"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <ComboBox Grid.Column="1"
                                  Width="220"
                                  HorizontalAlignment="Right"
                                  SelectedIndex="{x:Bind ViewModel.SelectedSshAuthorizationPromptIndex, Mode=TwoWay}">
                            <ComboBoxItem Content="记住直到密码库锁定" />
                            <ComboBoxItem Content="每次都提示" />
                            <ComboBoxItem Content="永不提示" />
                        </ComboBox>
                    </Grid>

                    <Grid ColumnSpacing="12" MinHeight="44">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="允许屏幕截图" FontWeight="SemiBold" />
                            <TextBlock Text="允许捕获桌面应用窗口内容"
                                       Style="{StaticResource SettingsDescriptionTextBlockStyle}" />
                        </StackPanel>
                        <ToggleSwitch Grid.Column="1"
                                      HorizontalAlignment="Right"
                                      IsOn="{x:Bind ViewModel.AllowScreenshots, Mode=TwoWay}" />
                    </Grid>

                    <Grid ColumnSpacing="12" MinHeight="44">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="主题" FontWeight="SemiBold" />
                            <TextBlock Text="更改应用颜色主题"
                                       Style="{StaticResource SettingsDescriptionTextBlockStyle}" />
                        </StackPanel>
                        <ComboBox Grid.Column="1"
                                  Width="220"
                                  HorizontalAlignment="Right"
                                  SelectedIndex="{x:Bind ViewModel.SelectedThemeIndex, Mode=TwoWay}">
                            <ComboBoxItem Content="默认（跟随系统）" />
                            <ComboBoxItem Content="浅色" />
                            <ComboBoxItem Content="深色" />
                        </ComboBox>
                    </Grid>

                    <Grid ColumnSpacing="12" MinHeight="44">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="语言" FontWeight="SemiBold" />
                            <TextBlock Text="更改应用显示语言"
                                       Style="{StaticResource SettingsDescriptionTextBlockStyle}" />
                        </StackPanel>
                        <ComboBox Grid.Column="1"
                                  Width="220"
                                  HorizontalAlignment="Right"
                                  SelectedIndex="{x:Bind ViewModel.SelectedLanguageIndex, Mode=TwoWay}">
                            <ComboBoxItem Content="zh-CN - 中文（中国大陆）" />
                            <ComboBoxItem Content="English" />
                        </ComboBox>
                    </Grid>
                </StackPanel>
            </Border>

            <Border BorderBrush="{ThemeResource SystemFillColorCriticalBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="16">
                <StackPanel Spacing="12">
                    <TextBlock Text="危险区" Style="{StaticResource SettingsCaptionTextBlockStyle}" />
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="删除账户" FontWeight="SemiBold" />
                            <TextBlock Text="永久删除您的账户与所有密码库数据"
                                       Style="{StaticResource SettingsDescriptionTextBlockStyle}" />
                        </StackPanel>
                        <Button Grid.Column="1" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE74D;"
                                          FontSize="14"
                                          Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                                <TextBlock Text="删除账户"
                                           Foreground="{ThemeResource SystemFillColorCriticalBrush}" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
