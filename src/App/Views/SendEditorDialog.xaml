<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="App.Views.SendEditorDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="using:App.Converters"
    Title="{x:Bind DialogTitle, Mode=OneWay}"
    PrimaryButtonText="保存"
    CloseButtonText="取消"
    PrimaryButtonClick="OnPrimaryButtonClick"
    DefaultButton="Primary">

    <ContentDialog.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
        <x:Double x:Key="ContentDialogMaxWidth">640</x:Double>
        <x:Double x:Key="ContentDialogMaxHeight">960</x:Double>
    </ContentDialog.Resources>

    <StackPanel Width="520"
                Spacing="18">
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <RadioButton Grid.Column="0"
                             Content="文本"
                             GroupName="SendType"
                             IsChecked="True"
                             Checked="OnTextChecked" />
                <RadioButton Grid.Column="1"
                             Content="文件"
                             GroupName="SendType"
                             Checked="OnFileChecked" />
            </Grid>

            <StackPanel Spacing="12">
                <TextBlock Text="Send 详细信息"
                           Style="{StaticResource SectionHeaderTextBlockStyle}" />

                <TextBox Header="Send 名称（必填）"
                         HorizontalAlignment="Stretch"
                         Text="{x:Bind Draft.Name, Mode=TwoWay}" />

                <StackPanel Visibility="{x:Bind Draft.IsText, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                            Spacing="8">
                    <TextBox Header="要分享的文本（必填）"
                             HorizontalAlignment="Stretch"
                             Text="{x:Bind Draft.Text, Mode=TwoWay}"
                             AcceptsReturn="True"
                             MinHeight="96"
                             TextWrapping="Wrap" />
                    <CheckBox IsChecked="{x:Bind Draft.HideTextByDefault, Mode=TwoWay}">
                        <TextBlock Text="默认隐藏文本"
                                   TextWrapping="Wrap" />
                    </CheckBox>
                </StackPanel>

                <StackPanel Visibility="{x:Bind Draft.IsFile, Mode=OneWay, Converter={StaticResource BoolToVis}}"
                            Spacing="8">
                    <TextBlock Text="要分享的文件（必填）" />
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Button Content="选择文件"
                                Click="OnChooseFileClick" />
                        <TextBlock Grid.Column="1"
                                   Text="{x:Bind Draft.FileName, Mode=OneWay}"
                                   VerticalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </Grid>
                    <TextBlock Text="文件最大为 500 MB。"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                </StackPanel>

                <ComboBox Header="删除日期（必填）"
                          HorizontalAlignment="Stretch"
                          SelectedItem="{x:Bind Draft.DeletionDateLabel, Mode=TwoWay}">
                    <x:String>1 天</x:String>
                    <x:String>7 天</x:String>
                    <x:String>30 天</x:String>
                </ComboBox>

                <TextBlock Text="此 Send 将在此日期后被永久删除。"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                <ComboBox Header="谁可以查看"
                          HorizontalAlignment="Stretch"
                          SelectedItem="{x:Bind Draft.ViewerLabel, Mode=TwoWay}">
                    <x:String>拥有链接的任何人</x:String>
                </ComboBox>
            </StackPanel>

            <StackPanel Spacing="12">
                <TextBlock Text="附加选项"
                           Style="{StaticResource SectionHeaderTextBlockStyle}" />

                <NumberBox Header="最大访问次数"
                           HorizontalAlignment="Stretch"
                           Value="{x:Bind MaxAccessCountValue, Mode=TwoWay}"
                           Minimum="0"
                           SpinButtonPlacementMode="Inline" />

                <TextBlock Text="达到限额后，任何人无法查看此 Send。"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                <CheckBox IsChecked="{x:Bind Draft.HideEmail, Mode=TwoWay}">
                    <TextBlock Text="对接收者隐藏我的电子邮箱地址"
                               TextWrapping="Wrap" />
                </CheckBox>

                <TextBox Header="私密备注"
                         HorizontalAlignment="Stretch"
                         Text="{x:Bind Draft.Notes, Mode=TwoWay}"
                         AcceptsReturn="True"
                         MinHeight="84"
                         TextWrapping="Wrap" />
            </StackPanel>
    </StackPanel>
</ContentDialog>
