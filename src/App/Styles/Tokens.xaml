<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============ 间距(4 的倍数,统一留白节奏) ============ -->
    <x:Double x:Key="SpacingXSmall">4</x:Double>
    <x:Double x:Key="SpacingSmall">8</x:Double>
    <x:Double x:Key="SpacingMedium">12</x:Double>
    <x:Double x:Key="SpacingLarge">16</x:Double>
    <x:Double x:Key="SpacingXLarge">24</x:Double>

    <!-- ============ 圆角 / 内边距 ============ -->
    <CornerRadius x:Key="CardCornerRadius">8</CornerRadius>
    <Thickness x:Key="CardContentPadding">16</Thickness>
    <Thickness x:Key="PageContentPadding">24</Thickness>

    <!-- ============ 文本层级 ============ -->
    <!-- 章节标题:取代各页手写的 12px 灰字,建立真正的层级 -->
    <Style x:Key="SectionHeaderTextBlockStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource BodyStrongTextBlockStyle}">
        <Setter Property="Margin" Value="0,0,0,4" />
    </Style>

    <!-- 卡片/字段标题等次要说明文字:统一一处,全局可调 -->
    <Style x:Key="CaptionSecondaryTextBlockStyle"
           TargetType="TextBlock"
           BasedOn="{StaticResource CaptionTextBlockStyle}">
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        <Setter Property="TextWrapping" Value="WrapWholeWords" />
    </Style>

    <!-- ============ 图标徽标容器(列表行 / 头像底色统一) ============ -->
    <Style x:Key="IconBadgeBorderStyle" TargetType="Border">
        <Setter Property="Background" Value="{ThemeResource ControlFillColorSecondaryBrush}" />
        <Setter Property="CornerRadius" Value="6" />
        <Setter Property="HorizontalAlignment" Value="Left" />
        <Setter Property="VerticalAlignment" Value="Center" />
    </Style>

    <!-- ============ 纯图标按钮(复制/显示/打开等),集中样式取代逐处内联 ============ -->
    <Style x:Key="IconButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="6" />
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="MinHeight" Value="0" />
    </Style>

</ResourceDictionary>
