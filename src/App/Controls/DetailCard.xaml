<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="App.Controls.DetailCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1" CornerRadius="{StaticResource CardCornerRadius}" Padding="12">
        <StackPanel Spacing="4">
            <TextBlock x:Name="TitleText"
                       Style="{StaticResource CaptionSecondaryTextBlockStyle}" />
            <ContentPresenter Content="{x:Bind CardContent, Mode=OneWay}" />
        </StackPanel>
    </Border>
</UserControl>
