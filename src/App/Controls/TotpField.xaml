<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="App.Controls.TotpField"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:muxc="using:Microsoft.UI.Xaml.Controls">
    <Grid ColumnSpacing="8" Padding="0,6">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="80" />
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock Text="TOTP" Foreground="{ThemeResource TextFillColorSecondaryBrush}" VerticalAlignment="Center" />
        <TextBlock x:Name="CodeText"
                   Grid.Column="1"
                   FontFamily="Consolas"
                   FontSize="16"
                   VerticalAlignment="Center" />
        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
            <muxc:ProgressRing x:Name="Ring" Width="18" Height="18" IsIndeterminate="False"
                               Minimum="0" Maximum="30" VerticalAlignment="Center" />
            <TextBlock x:Name="SecondsText" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       MinWidth="16" TextAlignment="Right" VerticalAlignment="Center" />
            <Button x:Name="CopyButton" Click="OnCopy"
                    Style="{StaticResource IconButtonStyle}"
                    AutomationProperties.Name="复制验证码"
                    ToolTipService.ToolTip="复制">
                <FontIcon Glyph="&#xE8C8;" FontSize="14" />
            </Button>
        </StackPanel>
    </Grid>
</UserControl>
