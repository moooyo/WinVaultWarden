{
  "manifest_version": 3,
  "name": "WinVaultWarden Browser Integration",
  "description": "Browser bridge for WinVaultWarden passkey and autofill integration.",
  "version": "0.1.0",
  "minimum_chrome_version": "116",
  "permissions": [
    "nativeMessaging"
  ],
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content-webauthn.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "src/page-webauthn.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}
